[configuration]

entry_symbol = "fluid_sim_library_init"
compatibility_minimum = "4.2"

[libraries]

windows.editor.x86_64 = "windows/GPUStableFluids2D.windows.editor.x86_64.dll"
windows.template_debug.x86_64 = "windows/GPUStableFluids2D.windows.template_debug.x86_64.dll"
windows.template_release.x86_64 = "windows/GPUStableFluids2D.windows.template_release.x86_64.dll"

linux.editor.x86_64 = "linux/libGPUStableFluids2D.linux.editor.x86_64.so"
linux.template_debug.x86_64 = "linux/libGPUStableFluids2D.linux.template_debug.x86_64.so"
linux.template_release.x86_64 = "linux/libGPUStableFluids2D.linux.template_release.x86_64.so"

macos.editor = "macos/libGPUStableFluids2D.macos.editor.framework"
macos.template_debug = "macos/libGPUStableFluids2D.macos.template_debug.framework"
macos.template_release = "macos/libGPUStableFluids2D.macos.template_release.framework"
